# ============================================================
# IT Helpdesk Incident Triage — OpenEnv
# Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# ----- Environment Server -----
# URL of the running OpenEnv backend (used by inference.py)
API_BASE_URL=http://localhost:7860

# ----- LLM Configuration (optional) -----
# OpenAI-compatible API endpoint for the LLM agent in inference.py
# Leave blank to use deterministic heuristic fallback
LLM_API_BASE=

# Model name to use for LLM inference
# Examples: gpt-4o-mini, meta-llama/Meta-Llama-3-8B-Instruct
MODEL_NAME=

# Hugging Face API token (used as OpenAI API key for HF Inference API)
HF_TOKEN=

# ----- Server Config -----
HOST=0.0.0.0
PORT=7860
